NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Keep this server-only. Never expose it in browser code.
# It is optional for the current app runtime and should only be used
# by future server-side admin scripts or secure back-office jobs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email reminder and cron settings
REMINDER_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
CRON_SECRET=your-random-cron-secret
